---
import brands from '../data/brands.json';
---

<html lang="ru">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>Coffeenautica - Матрица Брендов</title>
		<style>
			body { font-family: sans-serif; background: #f4f4f4; padding: 20px; }
			.matrix {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
				gap: 15px;
			}
			.brand-card {
				background: white;
				aspect-ratio: 1 / 1;
				display: flex;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				border-radius: 12px;
				box-shadow: 0 2px 5px rgba(0,0,0,0.05);
				transition: transform 0.2s;
				text-decoration: none;
				color: #333;
				padding: 10px;
			}
			.brand-card:hover { transform: scale(1.05); }
			.brand-card img {
				max-width: 64px;
				max-height: 64px;
				margin-bottom: 8px;
			}
			.brand-card span { font-size: 12px; font-weight: bold; text-align: center; }
		</style>
	</head>
	<body>
		<h1>Coffeenautica: Бренды Кофе</h1>
		<div class="matrix">
			{brands.map((brand) => (
				<a href={`/brands/${brand.slug}`} class="brand-card">
					<img src={`https://www.google.com/s2/favicons?sz=128&domain=${brand.domain}`} alt={brand.name} />
					<span>{brand.name}</span>
				</a>
			))}
		</div>
	</body>
</html>