---
import brands from '../data/brands.json';
---

<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>Coffeenautica</title>
</head>
<body>
    <main>
        <div class="brands-grid">
            {brands.map((brand) => (
                <div class="brand-card">
                    <img 
                        src={`https://www.google.com/s2/favicons?sz=64&domain=${brand.link.replace('https://', '').replace('www.', '').split('/')[0]}`} 
                        alt={brand.name}
                    />
                    <h3>{brand.name}</h3>
                    <p>{brand.description}</p>
                    <a href={brand.link}>Site</a>
                </div>
            ))}
        </div>
    </main>
</body>
</html>

<style>
    /* Простейшие стили, которые точно ничего не скроют */
    .brands-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        padding: 20px;
    }
    .brand-card {
        width: 250px;
        padding: 15px;
        border: 1px solid #ccc;
        border-radius: 8px;
        text-align: center;
    }
    .brand-card img {
        width: 32px;
        height: 32px;
        display: block;
        margin: 0 auto 10px;
    }
</style>