---
import brands from '../../data/brands.json';

export async function getStaticPaths() {
  return brands.map((brand) => {
    // Генерируем slug из имени: переводим в нижний регистр и меняем пробелы на дефисы
    const generatedSlug = brand.name
      .toLowerCase()
      .replace(/\s+/g, '-')       // Пробелы в дефисы
      .replace(/[^\w-]+/g, '')     // Удаляем всё, что не буквы и не дефисы
      .replace(/--+/g, '-')        // Убираем двойные дефисы
      .trim();

    return {
      params: { slug: generatedSlug },
      props: { brand },
    };
  });
}

const { brand } = Astro.props;
const amazonTag = "coffeenautica-20";
const amazonLink = `https://www.amazon.com/s?k=${encodeURIComponent(brand.name)}+coffee+beans&tag=${amazonTag}`;
